# --- Supabase (PostgreSQL) ---
NEXT_PUBLIC_SUPABASE_URL=stock-edge.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=supabase-anon-key-goes-here
# Server-only: prefer service role for API routes that insert data (never expose in client)
SUPABASE_SERVICE_ROLE_KEY=supabase-service-role-key-goes-here

# --- FastAPI backend (Render / local) ---
SUPABASE_URL=stock-edge.supabase.co
SUPABASE_KEY=supabase-service-role-key-goes-here
# Alias supported by this repo's FastAPI code:
SUPABASE_SERVICE_ROLE_KEY=supabase-service-role-key-goes-here

GEMINI_API_KEY=api-key-goes-here

# n8n workflow webhook (handles Telegram delivery)
N8N_WEBHOOK_URL=https://sidd1236664.app.n8n.cloud/webhook-test/stock-edge-alerts

# Default recipient when request omits telegram_chat_id (optional)
TELEGRAM_CHAT_ID=telegram-chat-id-goes-here

# Comma-separated origins for FastAPI CORS (optional; default *)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Frontend → FastAPI proxy (local / production)
NEXT_PUBLIC_API_URL=http://localhost:8000
